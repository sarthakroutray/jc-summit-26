# JC Summit — Frontend Environment Variables
# Copy this to .env.local and fill in your values

# ── Supabase ─────────────────────────────────────────────────
# Found in: Supabase Dashboard → Project Settings → API

# Your project's public URL (safe to expose to browser)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Anon / public key (safe to expose to browser, subject to RLS)
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Service role key (NEVER expose to browser — server/API routes only)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Optional server-only alias used by some environments
# If omitted, server code falls back to NEXT_PUBLIC_SUPABASE_URL
SUPABASE_URL=https://your-project-ref.supabase.co
